# ============================================================
# .env.example — Arquivo de exemplo para variáveis de ambiente
# ============================================================
#
# INSTRUÇÕES:
#   1. Copie este arquivo e renomeie para .env
#      macOS/Linux: cp .env.example .env
#      Windows:     copy .env.example .env
#
#   2. Preencha os valores com as suas configurações reais
#
#   ⚠️  NUNCA envie o arquivo .env para o GitHub!
#       Ele contém senhas e chaves secretas.
#       O .gitignore já está configurado para ignorá-lo.
#
# ============================================================

# Diz ao Flask qual arquivo é o ponto de entrada
FLASK_APP=run.py

# Ambiente da aplicação: "development", "testing" ou "production"
# FLASK_ENV foi removido no Flask 2.3 — use FLASK_CONFIG
FLASK_CONFIG=development

# Chave secreta para assinar cookies e tokens de segurança
# Gere uma chave forte com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=mude-essa-chave-em-producao-gere-uma-aleatoria

# URL de conexão com o banco de dados MySQL
# Formato: mysql+pymysql://USUARIO:SENHA@HOST/NOME_DO_BANCO
DATABASE_URL=mysql+pymysql://petpost_user:petpost123@localhost/petpost_dev
